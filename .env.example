# Claude API Key（使用 Anthropic provider 时必需）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI 兼容 API（DeepSeek / Kimi 等）
# AGENT_LLM_PROVIDER=openai
# AGENT_LLM_MODEL=deepseek-chat
# AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=sk-xxxxx

# Tavily 搜索 API（可选，免费注册 https://tavily.com）
# TAVILY_API_KEY=tvly-xxxxx

# Voyage Embedding API（可选，不配则使用本地 sentence-transformers）
# VOYAGE_API_KEY=pa-xxxxx

# HuggingFace 镜像（可选，国内加速下载模型）
# HF_ENDPOINT=https://hf-mirror.com

# 覆盖 settings.yaml 中的配置（可选）
# AGENT_LLM_MODEL=claude-sonnet-4-20250514
# AGENT_LLM_MAX_TOKENS=4096
